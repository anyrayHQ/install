{
  "displayName": "Anyray",
  "description": "Self-hosted AI-spend optimizer — gateway, optimizer, and observability console.",
  "tags": ["ai", "gateway", "llm", "observability"],
  "icon": "https://docs.anyray.ai/img/favicon.svg",
  "readme": "https://raw.githubusercontent.com/anyrayHQ/install/main/railway/README.md",
  "services": [
    {
      "name": "gateway",
      "source": {
        "image": "ghcr.io/anyrayhq/gateway:stable"
      },
      "deploy": {
        "healthcheckPath": "/",
        "restartPolicyType": "ON_FAILURE"
      },
      "volumes": [{ "mountPath": "/data" }],
      "variables": {
        "PORT": "8787",
        "ANYRAY_OBSERVABILITY_DB_URL": "${{Postgres.DATABASE_URL}}",
        "ANYRAY_SPEND_DB_URL": "${{Postgres.DATABASE_URL}}",
        "ANYRAY_OPTIMIZER_URL": "http://${{optimizer.RAILWAY_PRIVATE_DOMAIN}}:8088",
        "ANYRAY_OPTIMIZER_TOKEN": "${{optimizer.ANYRAY_OPTIMIZER_TOKEN}}",
        "ANYRAY_OPTIMIZER_TIMEOUT_MS": "800",
        "ANYRAY_OPTIMIZER_VISION_TIMEOUT_MS": "10000",
        "ANYRAY_DEFAULT_MODEL": "anthropic/claude-sonnet-4-5",
        "ANYRAY_CONTENT_KEY": "${{secret(64, \"0123456789abcdef\")}}",
        "ANYRAY_CONTENT_MODE": "encrypted",
        "ANYRAY_ALLOW_PLAINTEXT": "false",
        "ANYRAY_ADMIN_TOKEN": "${{secret()}}",
        "ANYRAY_DATA_DIR": "/data",
        "ANYRAY_GATEWAY_PUBLIC_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
        "ANYRAY_CONSOLE_PUBLIC_URL": "https://${{proxy.RAILWAY_PUBLIC_DOMAIN}}",
        "ANYRAY_REQUIRE_CLIENT_KEYS": "",
        "ANYRAY_REQUIRE_VERIFIED_DEV": "",
        "ANYRAY_HSTS": "true",
        "ANYRAY_TRUST_PROXY": "true",
        "ANYRAY_RATE_LIMIT_RPM": "",
        "ANYRAY_RATE_LIMIT_IP_RPM": "",
        "ANYRAY_RATE_LIMIT_UNAUTH_RPM": "",
        "ANYRAY_MAX_CONCURRENT_REQUESTS": "",
        "ANYRAY_AUTH_FAIL_LIMIT": "",
        "ANYRAY_MAX_BODY_BYTES": "",
        "ANYRAY_UPSTREAM_URL": "",
        "ANYRAY_CUSTOM_HOST_ALLOWLIST": "",
        "TRUSTED_CUSTOM_HOSTS": ""
      }
    },
    {
      "name": "optimizer",
      "source": {
        "image": "ghcr.io/anyrayhq/optimizer:stable"
      },
      "deploy": {
        "healthcheckPath": "/health",
        "restartPolicyType": "ON_FAILURE"
      },
      "volumes": [{ "mountPath": "/data" }],
      "variables": {
        "PORT": "8088",
        "ANYRAY_OPTIMIZER_TOKEN": "${{secret()}}",
        "ANYRAY_ADMIN_TOKEN": "${{gateway.ANYRAY_ADMIN_TOKEN}}",
        "ANYRAY_DATA_DIR": "/data"
      }
    },
    {
      "name": "proxy",
      "source": {
        "image": "ghcr.io/anyrayhq/proxy:stable"
      },
      "deploy": {
        "healthcheckPath": "/anyray-login",
        "restartPolicyType": "ON_FAILURE"
      },
      "variables": {
        "ANYRAY_GATEWAY_HOST": "${{gateway.RAILWAY_PRIVATE_DOMAIN}}",
        "ANYRAY_OPTIMIZER_HOST": "${{optimizer.RAILWAY_PRIVATE_DOMAIN}}",
        "ANYRAY_UPDATER_ENABLED": "false",
        "ANYRAY_UPDATER_PERIODIC_POLLS": "false",
        "ANYRAY_UPDATER_POLL_INTERVAL": "86400",
        "ANYRAY_UPDATER_TOKEN": "${{secret()}}"
      }
    },
    {
      "name": "Postgres",
      "source": {
        "image": "ghcr.io/railwayapp-templates/postgres-ssl:17"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE"
      },
      "volumes": [{ "mountPath": "/var/lib/postgresql/data" }],
      "variables": {
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "${{secret()}}",
        "POSTGRES_DB": "postgres",
        "PGDATA": "/var/lib/postgresql/data/pgdata",
        "DATABASE_URL": "postgresql://${{Postgres.POSTGRES_USER}}:${{Postgres.POSTGRES_PASSWORD}}@${{Postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/${{Postgres.POSTGRES_DB}}"
      }
    }
  ]
}
