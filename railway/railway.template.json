{
  "displayName": "Anyray",
  "description": "Self-hosted AI-spend optimizer \u2014 gateway, optimizer, and observability console.",
  "tags": [
    "ai",
    "gateway",
    "llm",
    "observability"
  ],
  "icon": "https://docs.anyray.ai/img/favicon.svg",
  "readme": "https://raw.githubusercontent.com/anyrayHQ/install/main/railway/README.md",
  "services": [
    {
      "name": "gateway",
      "source": {
        "image": "ghcr.io/anyrayhq/gateway:stable"
      },
      "deploy": {
        "healthcheckPath": "/",
        "restartPolicyType": "ON_FAILURE"
      },
      "volumes": [
        {
          "mountPath": "/data"
        }
      ],
      "variables": {
        "PORT": "8787",
        "ANYRAY_OBSERVABILITY_DB_URL": "postgresql://${{Postgres.POSTGRES_USER}}:${{Postgres.POSTGRES_PASSWORD}}@${{Postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/${{Postgres.POSTGRES_DB}}",
        "ANYRAY_OPTIMIZER_URL": "http://${{optimizer.RAILWAY_PRIVATE_DOMAIN}}:8088",
        "ANYRAY_OPTIMIZER_TOKEN": "${{optimizer.ANYRAY_OPTIMIZER_TOKEN}}",
        "ANYRAY_OPTIMIZER_TIMEOUT_MS": "800",
        "ANYRAY_OPTIMIZER_VISION_TIMEOUT_MS": "10000",
        "ANYRAY_CONTENT_KEY": "${{secret(64, \"0123456789abcdef\")}}",
        "ANYRAY_CONTENT_MODE": "encrypted",
        "ANYRAY_ALLOW_PLAINTEXT": "false",
        "ANYRAY_ADMIN_TOKEN": "${{secret()}}",
        "ANYRAY_SETTINGS_FILE": "/data/anyray-settings.json",
        "ANYRAY_AUDIT_FILE": "/data/anyray-settings-audit.log",
        "ANYRAY_SPEND_FILE": "/data/spend.jsonl",
        "ANYRAY_PROVIDER_KEYS_FILE": "/data/provider-keys.config.json",
        "ANYRAY_PROVIDER_KEYS_AUDIT_FILE": "/data/provider-keys-audit.log",
        "ANYRAY_ROUTING_CONFIG_FILE": "/data/routing.config.json",
        "ANYRAY_ROUTING_CONFIG_AUDIT_FILE": "/data/routing-config-audit.log",
        "ANYRAY_PRICING_CONFIG": "/data/pricing.config.json",
        "ANYRAY_PRICING_AUDIT_FILE": "/data/pricing-settings-audit.log",
        "ANYRAY_CLIENT_KEYS_FILE": "/data/client-keys.config.json",
        "ANYRAY_CLIENT_KEYS_AUDIT_FILE": "/data/client-keys-audit.log",
        "ANYRAY_USER_CAPS_FILE": "/data/user-caps.config.json",
        "ANYRAY_USER_CAPS_AUDIT_FILE": "/data/user-caps-audit.log",
        "ANYRAY_ENTITLEMENT_FILE": "/data/entitlement.lease.json",
        "ANYRAY_GATEWAY_PUBLIC_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
        "ANYRAY_CONSOLE_PUBLIC_URL": "https://${{proxy.RAILWAY_PUBLIC_DOMAIN}}",
        "ANYRAY_REQUIRE_CLIENT_KEYS": "",
        "ANYRAY_REQUIRE_VERIFIED_DEV": "",
        "ANYRAY_HSTS": "true",
        "ANYRAY_TRUST_PROXY": "true",
        "ANYRAY_RATE_LIMIT_RPM": "",
        "ANYRAY_RATE_LIMIT_IP_RPM": "",
        "ANYRAY_RATE_LIMIT_UNAUTH_RPM": "",
        "ANYRAY_MAX_CONCURRENT_REQUESTS": "",
        "ANYRAY_AUTH_FAIL_LIMIT": "",
        "ANYRAY_MAX_BODY_BYTES": "",
        "ANYRAY_UPSTREAM_URL": "",
        "ANYRAY_CUSTOM_HOST_ALLOWLIST": "",
        "TRUSTED_CUSTOM_HOSTS": ""
      }
    },
    {
      "name": "optimizer",
      "source": {
        "image": "ghcr.io/anyrayhq/optimizer:stable"
      },
      "deploy": {
        "healthcheckPath": "/health",
        "restartPolicyType": "ON_FAILURE"
      },
      "volumes": [
        {
          "mountPath": "/data"
        }
      ],
      "variables": {
        "PORT": "8088",
        "ANYRAY_OPTIMIZER_TOKEN": "${{secret()}}",
        "ANYRAY_ADMIN_TOKEN": "${{gateway.ANYRAY_ADMIN_TOKEN}}",
        "ANYRAY_OPTIMIZER_CONFIG": "/data/optimizer.config.json",
        "ANYRAY_OPTIMIZER_AUDIT_FILE": "/data/optimizer-settings-audit.log"
      }
    },
    {
      "name": "proxy",
      "source": {
        "image": "ghcr.io/anyrayhq/proxy:stable"
      },
      "deploy": {
        "healthcheckPath": "/anyray-login",
        "restartPolicyType": "ON_FAILURE"
      },
      "variables": {
        "ANYRAY_GATEWAY_HOST": "gateway.railway.internal",
        "ANYRAY_OPTIMIZER_HOST": "optimizer.railway.internal",
        "ANYRAY_UPDATER_ENABLED": "false",
        "ANYRAY_UPDATER_PERIODIC_POLLS": "false",
        "ANYRAY_UPDATER_POLL_INTERVAL": "86400",
        "ANYRAY_UPDATER_TOKEN": ""
      }
    },
    {
      "name": "Postgres",
      "source": {
        "image": "ghcr.io/railwayapp-templates/postgres-ssl:17"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE"
      },
      "volumes": [
        {
          "mountPath": "/var/lib/postgresql/data"
        }
      ],
      "variables": {
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "${{secret()}}",
        "POSTGRES_DB": "postgres",
        "PGDATA": "/var/lib/postgresql/data/pgdata",
        "DATABASE_URL": "postgresql://${{Postgres.POSTGRES_USER}}:${{Postgres.POSTGRES_PASSWORD}}@${{Postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/${{Postgres.POSTGRES_DB}}"
      }
    }
  ]
}
